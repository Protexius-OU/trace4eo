# VM hostname or IP address (used for Keycloak public URL and frontend redirect URIs)
VM_HOST=your-vm-ip-or-domain

# PostgreSQL credentials for the trace4eo application database
DB_USER=trace4eo
DB_PASSWORD=change_me_db

# PostgreSQL credentials for the Keycloak database
KC_DB_PASSWORD=change_me_kc_db

# Keycloak admin console credentials
KEYCLOAK_ADMIN_PASSWORD=change_me_admin
