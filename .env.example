# VM hostname or domain (used for Keycloak public URL, frontend redirect URIs, and TLS cert)
# For a free domain without DNS setup, use nip.io: e.g. 1-2-3-4.nip.io (replace with your IP)
VM_HOST=your-domain-or-subdomain

# Email for Let's Encrypt certificate registration (required)
ADMIN_EMAIL=your-email@example.com

# PostgreSQL credentials for the trace4eo application database
DB_USER=trace4eo
DB_PASSWORD=change_me_db

# PostgreSQL credentials for the Keycloak database
KC_DB_PASSWORD=change_me_kc_db

# Keycloak admin console credentials
KEYCLOAK_ADMIN_PASSWORD=change_me_admin
