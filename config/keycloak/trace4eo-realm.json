{
  "realm": "trace4eo",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "trace4eo-ui",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8080"
      ],
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8080/*"
      ],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true"
      }
    }
  ],
  "clientScopeMappings": {
    "broker": [
      {
        "client": "trace4eo-ui",
        "roles": ["read-token"]
      }
    ]
  },
  "identityProviders": [
    {
      "alias": "sigstore",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "sigstore",
        "clientAuthMethod": "none",
        "authorizationUrl": "https://oauth2.sigstore.dev/auth/auth",
        "tokenUrl": "https://oauth2.sigstore.dev/auth/token",
        "jwksUrl": "https://oauth2.sigstore.dev/auth/keys",
        "issuer": "https://oauth2.sigstore.dev/auth",
        "defaultScope": "openid email",
        "pkceEnabled": "true",
        "pkceMethod": "S256",
        "syncMode": "FORCE"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "sigstore-signer-role",
      "identityProviderAlias": "sigstore",
      "identityProviderMapper": "oidc-hardcoded-role-idp-mapper",
      "config": {
        "role": "signer"
      }
    },
    {
      "name": "sigstore-broker-read-token",
      "identityProviderAlias": "sigstore",
      "identityProviderMapper": "oidc-hardcoded-role-idp-mapper",
      "config": {
        "role": "broker.read-token"
      }
    }
  ],
  "users": [
    {
      "username": "testuser",
      "email": "testuser@trace4eo.local",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-trace4eo",
        "signer"
      ]
    },
    {
      "username": "admin",
      "email": "admin@trace4eo.local",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "adminpassword",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-trace4eo",
        "signer",
        "admin"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "signer",
        "description": "Can upload and sign provenance records"
      },
      {
        "name": "admin",
        "description": "Full administrative access"
      }
    ]
  }
}
